{
  "private": true,
  "name": "ultrawide-shortcuts",
  "type": "module",
  "scripts": {
    "lint": "eslint extension.js positioning.js prefs.js drag-snap.js edge-snap.js",
    "lint:fix": "eslint --fix extension.js positioning.js prefs.js drag-snap.js edge-snap.js",
    "reload": "./dev.sh reload",
    "logs": "./dev.sh logs",
    "nested": "./dev.sh nested",
    "pack": "gnome-extensions pack . --extra-source=positioning.js --extra-source=drag-snap.js --extra-source=edge-snap.js --out-dir=dist --force"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^16.0.0"
  }
}
